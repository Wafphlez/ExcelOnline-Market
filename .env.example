# EVE Third Party — приложение с Redirect URI (SPA).
# @see https://developers.eveonline.com/
VITE_EVE_SSO_CLIENT_ID=
# Необязательно: если пусто — origin без «/» в конце на корневом пути (как в CCP: http://127.0.0.1:5173).
# CCP сравнивает redirect URI буквально: «/» в конце и без — разные значения.
# VITE_EVE_SSO_REDIRECT_URI=http://127.0.0.1:5173

# GitHub Pages (локальная проверка сборки в подкаталоге): положите слэш в конце.
# В CI задаётся через переменные репозитория / workflow — см. .github/workflows/deploy-github-pages.yml
# VITE_BASE_PATH=/ExcelOnlineMarket/
